# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=3600

# Runtime mode
INFERENCE_MODE=base
ALLOW_DEV_FALLBACK=false

# Model and artifact configuration
MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0
ADAPTER_PATH=artifacts/train_runs/latest/adapter
MAX_INPUT_TOKENS=512
MAX_NEW_TOKENS=120

# Dataset and evaluation
DATASET_DIR=data/splits
TRAIN_SPLIT_PATH=data/splits/train.jsonl
VALIDATION_SPLIT_PATH=data/splits/validation.jsonl
TEST_SPLIT_PATH=data/splits/test.jsonl
DATASET_SIZE=480
DATASET_SEED=42

# Training defaults
TRAINING_EPOCHS=1
MAX_STEPS=120
LEARNING_RATE=0.0002
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
